# ─── Database ─────────────────────────────────────────────────────────────────
# Neon Postgres (free tier): https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xyz.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── Redis Cache ──────────────────────────────────────────────────────────────
# Upstash Redis (free tier, serverless): https://upstash.com
UPSTASH_REDIS_REST_URL="https://your-redis-id.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token-here"

# ─── AI Content Generation ────────────────────────────────────────────────────
# OpenAI API key: https://platform.openai.com
# Uses gpt-4o-mini (cheapest, ~$0.0001/article)
# Leave empty to use rule-based fallback (no AI cost)
OPENAI_API_KEY="sk-proj-your-openai-key-here"

# ─── Pipeline Security ────────────────────────────────────────────────────────
# Random 32+ character secret — used to secure /api/pipeline endpoint
# Generate: openssl rand -hex 32
PIPELINE_SECRET="your-random-32-char-secret-here"

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Used by GitHub Actions to call the pipeline endpoint
SITE_URL="https://microsoftupdates.co.in"
